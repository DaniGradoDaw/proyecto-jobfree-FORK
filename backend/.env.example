# Copia este archivo como .env y rellena los valores reales
# El archivo .env NUNCA debe subirse al repositorio

# Base de datos
DB_URL=jdbc:mysql://localhost:3306/jobfree?useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# JWT — genera una clave aleatoria de al menos 32 caracteres
# Ejemplo: openssl rand -base64 48
JWT_SECRET=CAMBIA_ESTO_POR_UNA_CLAVE_ALEATORIA_SEGURA

# Email SMTP Gmail
# Genera una App Password en: Cuenta de Google → Seguridad → Contraseñas de aplicaciones
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Google OAuth2 — obten las credenciales en console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2 — obten las credenciales en portal.azure.com
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Perfil Spring (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# Cookie segura (false en dev/HTTP, true en prod/HTTPS)
COOKIE_SECURE=false

# Rate limiting — máximo de peticiones por minuto en endpoints sensibles (default: 10)
RATE_LIMIT_MAX=10
TRUST_X_FORWARDED_FOR=false

# Stripe — solo necesario si usas pagos con tarjeta
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
